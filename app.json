{
  "expo": {
    "name": "OpenStream",
    "slug": "openstream",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080808"
      },
      "usesCleartextTraffic": true,
      "package": "com.openstream.app"
    }
  }
}
